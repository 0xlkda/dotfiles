[init]
  defaultBranch = main

[credential]
  helper = cache

[credential "https://github.com"]
	helper = 
	helper = !/Users/alex/.nix-profile/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper = 
	helper = !/Users/alex/.nix-profile/bin/gh auth git-credential

[alias]
  view = !$(which gh) browse
  wt = worktree
  cwt = !sh $HOME/code/dotfiles/clone-for-worktree.sh
  unstage = reset HEAD --
  untrack = rm --cached --
  last = log -1 HEAD
  diffs = diff --staged --
  rename = mv --

[push]
  autoSetupRemote = true
  default = current

[pull]
  rebase = true

[gpg]
  format = ssh

[gpg "ssh"]
  program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[commit]
  gpgsign = true

[merge]
  tool = nvimdiff2

[mergetool]
  keepBackup = false
